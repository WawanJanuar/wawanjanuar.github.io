---
const navLinks = [
  { label: "Thesis", href: "#thesis" },
  { label: "Portfolio", href: "#portfolio" },
  { label: "Founder", href: "#founder" },
  { label: "Growth", href: "#growth" },
];
---

<nav>
  <div class="nav-logo">
    <img src="/assets/logo-cw.png" alt="Capital Wawan" />
  </div>
  <div class="nav-links">
    {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
  </div>
  <button
    class="nav-toggle"
    id="navToggle"
    aria-label="Buka menu navigasi"
    aria-expanded="false"
    aria-controls="navMobileMenu"
  >
    <span></span>
    <span></span>
    <span></span>
  </button>
  <div class="nav-mobile-menu" id="navMobileMenu">
    <div class="nav-mobile-links">
      {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </div>
  </div>
</nav>
<div class="nav-mobile-backdrop" id="navMobileBackdrop"></div>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 40px;
    background: linear-gradient(to bottom, rgba(10, 10, 11, 0.95), rgba(10, 10, 11, 0));
    backdrop-filter: blur(6px);
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .nav-logo img {
    height: 26px;
    width: auto;
    transition: transform 0.3s ease, filter 0.3s ease;
  }

  .nav-logo:hover img {
    transform: scale(1.06);
    filter: drop-shadow(0 0 10px rgba(232, 17, 45, 0.35));
  }

  .nav-links {
    display: flex;
    gap: 36px;
    font-size: 13px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--muted);
  }

  .nav-links a {
    position: relative;
    padding-bottom: 4px;
    transition: color 0.2s;
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 0;
    width: 100%;
    height: 1px;
    background: var(--red);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s ease;
  }

  .nav-links a:hover {
    color: var(--text);
  }

  .nav-links a:hover::after {
    transform: scaleX(1);
    transform-origin: left;
  }

  /* Mobile hamburger toggle — hidden on desktop, matches the existing 780px breakpoint */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 6px;
    width: 44px;
    height: 44px;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    z-index: 101;
  }

  .nav-toggle span {
    display: block;
    width: 22px;
    height: 2px;
    margin: 0 auto;
    background: var(--text);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .nav-toggle[aria-expanded="true"] span:nth-child(1) {
    transform: translateY(8px) rotate(45deg);
  }

  .nav-toggle[aria-expanded="true"] span:nth-child(2) {
    opacity: 0;
  }

  .nav-toggle[aria-expanded="true"] span:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
  }

  /* Mobile dropdown menu — a floating frosted-glass card, not an edge-to-edge
     panel, to read as a distinct elevated surface (iOS-style) rather than a
     flat dropdown. Fixed positioning (not relative to nav) so it can float
     with its own margin instead of spanning full width. */
  .nav-mobile-menu {
    display: none;
  }

  .nav-mobile-backdrop {
    display: none;
  }

  @media (max-width: 780px) {
    .nav-links {
      display: none;
    }

    nav {
      padding: 18px 20px;
    }

    .nav-toggle {
      display: flex;
    }

    .nav-mobile-backdrop {
      display: block;
      position: fixed;
      inset: 0;
      z-index: 98;
      background: rgba(0, 0, 0, 0.45);
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.35s ease;
    }

    .nav-mobile-backdrop.is-open {
      opacity: 1;
      pointer-events: auto;
    }

    .nav-mobile-menu {
      display: block;
      position: fixed;
      top: 72px;
      left: 14px;
      right: 14px;
      z-index: 99;
      border-radius: 22px;
      background: rgba(30, 30, 32, 0.9);
      backdrop-filter: blur(46px) saturate(180%);
      -webkit-backdrop-filter: blur(46px) saturate(180%);
      border: 1px solid rgba(255, 255, 255, 0.12);
      box-shadow:
        0 24px 60px -12px rgba(0, 0, 0, 0.65),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
      opacity: 0;
      transform: translateY(-10px) scale(0.96);
      pointer-events: none;
      transition: opacity 0.35s cubic-bezier(0.19, 1, 0.22, 1), transform 0.35s cubic-bezier(0.19, 1, 0.22, 1);
      overflow: hidden;
    }

    .nav-mobile-menu.is-open {
      opacity: 1;
      transform: translateY(0) scale(1);
      pointer-events: auto;
    }

    .nav-mobile-links {
      display: flex;
      flex-direction: column;
      padding: 10px;
    }

    .nav-mobile-links a {
      font-family: var(--font-mono);
      font-size: 15px;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      color: var(--text);
      padding: 16px 14px;
      border-radius: 14px;
      transition: background-color 0.2s ease;
    }

    .nav-mobile-links a:not(:last-child) {
      margin-bottom: 2px;
    }

    .nav-mobile-links a:hover,
    .nav-mobile-links a:active {
      background: rgba(255, 255, 255, 0.1);
    }
  }
</style>

<script>
  const toggle = document.getElementById("navToggle");
  const menu = document.getElementById("navMobileMenu");
  const backdrop = document.getElementById("navMobileBackdrop");

  if (toggle && menu && backdrop) {
    const closeMenu = () => {
      toggle.setAttribute("aria-expanded", "false");
      menu.classList.remove("is-open");
      backdrop.classList.remove("is-open");
    };

    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!isOpen));
      menu.classList.toggle("is-open", !isOpen);
      backdrop.classList.toggle("is-open", !isOpen);
    });

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", closeMenu);
    });

    backdrop.addEventListener("click", closeMenu);

    document.addEventListener("click", (e) => {
      const target = e.target as Node;
      if (!menu.contains(target) && !toggle.contains(target) && !backdrop.contains(target)) {
        closeMenu();
      }
    });
  }
</script>
