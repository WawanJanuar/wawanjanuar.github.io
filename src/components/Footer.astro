---
const year = new Date().getFullYear();
---

<footer class="wrap">
  <div class="foot-logo">
    <img src="/assets/logo-cw.png" alt="Capital Wawan" />
    <span class="foot-copy">&copy; {year} Capital Wawan</span>
  </div>
  <div class="foot-links">
    <a href="#thesis">Thesis</a>
    <a href="#portfolio">Portfolio</a>
    <a href="#founder">Founder</a>
  </div>
</footer>

<style>
  footer {
    padding: 40px 0;
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  footer .foot-logo {
    display: flex;
    align-items: center;
    gap: 10px;
  }

  footer .foot-logo img {
    height: 20px;
  }

  footer .foot-copy {
    font-size: 12px;
    color: var(--muted);
    font-family: var(--font-mono);
  }

  footer .foot-links {
    display: flex;
    gap: 24px;
    font-size: 12px;
    color: var(--muted);
  }
</style>
