---
import type { Holding } from "../data/portfolio";

interface Props {
  holding: Holding;
}

const { holding } = Astro.props;
---

<div class="ticker-card">
  <div class="ticker-top">
    <span class="ticker-symbol">{holding.symbol}</span>
    <span class="ticker-badge">{holding.category}</span>
  </div>
  <div class="ticker-name">{holding.name}</div>
  <div class="ticker-desc">{holding.desc}</div>
  <svg class="ticker-spark" viewBox="0 0 200 44" preserveAspectRatio="none">
    <path d={holding.sparkline}></path>
  </svg>
</div>

<style>
  .ticker-card {
    position: relative;
    padding: 36px 32px;
    border-radius: 18px;
    overflow: hidden;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.05), rgba(255, 255, 255, 0) 40%),
      rgba(20, 20, 22, 0.55);
    border: 1px solid rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    box-shadow:
      0 20px 50px -18px rgba(0, 0, 0, 0.75),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    transition: transform 0.35s ease, box-shadow 0.35s ease, border-color 0.35s ease;
  }

  .ticker-card::before {
    content: "";
    position: absolute;
    top: var(--mx, 50%);
    left: var(--my, 50%);
    width: 420px;
    height: 420px;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(232, 17, 45, 0.28), transparent 65%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .ticker-card:hover {
    transform: translateY(-4px);
    border-color: rgba(232, 17, 45, 0.35);
    box-shadow:
      0 28px 60px -16px rgba(0, 0, 0, 0.8),
      0 0 40px rgba(232, 17, 45, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.12);
  }

  .ticker-card:hover::before {
    opacity: 1;
  }

  .ticker-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 28px;
  }

  .ticker-symbol {
    font-family: var(--font-mono);
    font-size: 14px;
    letter-spacing: 0.06em;
    color: var(--muted);
  }

  .ticker-badge {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 4px 9px;
    border-radius: 3px;
    background: rgba(232, 17, 45, 0.12);
    color: var(--red);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .ticker-name {
    font-size: 22px;
    font-family: var(--font-display);
    font-weight: 800;
    font-stretch: 108%;
    margin-bottom: 10px;
  }

  .ticker-desc {
    font-size: 14px;
    color: var(--muted);
    line-height: 1.6;
    margin-bottom: 28px;
    min-height: 64px;
  }

  .ticker-spark {
    height: 44px;
    width: 100%;
  }

  .ticker-spark path {
    fill: none;
    stroke: var(--red);
    stroke-width: 1.6;
  }
</style>
