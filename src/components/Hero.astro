<section class="hero">
  <canvas id="heroNetwork" class="hero-network-bg"></canvas>
  <div class="wrap">
    <div class="hero-eyebrow">Family Office &mdash; Saham &amp; Crypto</div>
    <h1>Investasi bukan tempat untuk mencari kekayaan, <em>tapi menggandakan kekayaan.</em></h1>
    <p class="hero-sub">
      Capital Wawan adalah kendaraan investasi pribadi yang mengelola portofolio saham
      domestik dan aset digital dengan pendekatan jangka panjang, berbasis riset, dan tanpa
      modal dari pihak luar.
    </p>
    <div class="hero-meta">
      <div>
        <div class="num">2023</div>
        <div class="lbl">Tahun Berdiri</div>
      </div>
      <div>
        <div class="num">3</div>
        <div class="lbl">Current Holding</div>
      </div>
      <div>
        <div class="num">+$$$$$</div>
        <div class="lbl">Unlimited Money</div>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    padding: 140px 0 80px;
    border-bottom: 1px solid var(--line);
  }

  .hero::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 900px 500px at 85% 15%, rgba(232, 17, 45, 0.14), transparent 60%),
      radial-gradient(ellipse 700px 400px at 10% 90%, rgba(232, 17, 45, 0.08), transparent 60%);
    pointer-events: none;
    z-index: 1;
  }

  .hero-network-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    -webkit-mask-image: linear-gradient(100deg, transparent 0%, black 35%, black 100%);
    mask-image: linear-gradient(100deg, transparent 0%, black 35%, black 100%);
  }

  .hero .wrap {
    position: relative;
    z-index: 2;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--red);
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 28px;
  }

  .hero-eyebrow::before {
    content: "";
    width: 7px;
    height: 7px;
    background: var(--red);
    border-radius: 50%;
    box-shadow: 0 0 0 4px rgba(232, 17, 45, 0.15);
  }

  .hero h1 {
    font-size: clamp(32px, 5.2vw, 68px);
    max-width: 980px;
    color: var(--text);
  }

  .hero h1 em {
    font-style: normal;
    color: var(--red);
  }

  .hero-sub {
    margin-top: 28px;
    max-width: 620px;
    font-size: 17px;
    line-height: 1.7;
    color: var(--muted);
  }

  .hero-meta {
    margin-top: 56px;
    display: flex;
    gap: 48px;
    flex-wrap: wrap;
    padding-top: 32px;
    border-top: 1px solid var(--line);
    max-width: 820px;
  }

  .hero-meta div {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .hero-meta .num {
    font-family: var(--font-mono);
    font-size: 26px;
    color: var(--text);
  }

  .hero-meta .lbl {
    font-size: 12px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
</style>

<script>
  import { initHeroNetwork } from "../scripts/heroNetwork";
  initHeroNetwork();
</script>
