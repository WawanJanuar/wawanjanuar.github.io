---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Capital Wawan",
  description = "Wawan Januar, founder Capital Wawan — family office yang mengelola portofolio saham domestik (IDX) dan aset kripto sejak 2023. Trader aktif di industri crypto dan pasar modal Indonesia.",
} = Astro.props;

const instagramUrl = "https://www.instagram.com/wawanjanuarr/";
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Wawan Januar" />
    <link rel="canonical" href="https://wawanjanuar.github.io/" />

    <!-- Open Graph (Facebook, WhatsApp, LinkedIn preview) -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content="Wawan Januar — Founder Capital Wawan" />
    <meta
      property="og:description"
      content="Family office yang mengelola portofolio saham domestik dan aset kripto. Dikelola langsung oleh Wawan Januar sejak 2023."
    />
    <meta property="og:image" content="https://wawanjanuar.github.io/assets/logo-cw.png" />
    <meta property="og:url" content="https://wawanjanuar.github.io/" />
    <meta property="og:site_name" content="Capital Wawan" />
    <meta property="og:locale" content="id_ID" />

    <!-- Twitter / X Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Wawan Januar — Founder Capital Wawan" />
    <meta
      name="twitter:description"
      content="Family office yang mengelola portofolio saham domestik dan aset kripto sejak 2023."
    />
    <meta name="twitter:image" content="https://wawanjanuar.github.io/assets/logo-cw.png" />

    <!-- Favicon — square-padded versions of logo-cw.png (the raw 454x156 rectangular
         logo squishes into an unreadable mark when a browser tab forces it into a
         16-32px square), generated from the same source file, not redrawn. -->
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <meta name="generator" content={Astro.generator} />

    <!-- JSON-LD Structured Data — Person -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Wawan Januar",
      "alternateName": "Wawan",
      "jobTitle": "Founder, Capital Wawan",
      "description": "Trader dan pengelola portofolio saham domestik serta aset kripto, founder Capital Wawan.",
      "url": "https://wawanjanuar.github.io/",
      "image": "https://wawanjanuar.github.io/assets/profile-wawan.png",
      "worksFor": {
        "@type": "Organization",
        "name": "Capital Wawan",
        "foundingDate": "2023",
        "url": "https://wawanjanuar.github.io/"
      },
      "sameAs": [instagramUrl]
    })} />

    <!-- JSON-LD Structured Data — Organization -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Capital Wawan",
      "url": "https://wawanjanuar.github.io/",
      "logo": "https://wawanjanuar.github.io/assets/logo-cw.png",
      "foundingDate": "2023",
      "founder": {
        "@type": "Person",
        "name": "Wawan Januar"
      },
      "description": "Family office yang mengelola portofolio saham domestik (IDX) dan aset kripto."
    })} />

    <script is:inline>
      // A reload after clicking an in-page anchor (e.g. #thesis) would otherwise land
      // mid-page, since browsers auto-scroll to a URL hash on load. This is a one-page
      // site, so every load should start at the top instead.
      if (window.location.hash) {
        history.scrollRestoration = "manual";
        window.history.replaceState(null, "", window.location.pathname + window.location.search);
        window.scrollTo(0, 0);
      }
    </script>
  </head>
  <body>
    <slot />
    <script>
      import { initReveal } from "../scripts/reveal";
      import { initParallax } from "../scripts/parallax";
      initReveal();
      initParallax();
    </script>
  </body>
</html>
